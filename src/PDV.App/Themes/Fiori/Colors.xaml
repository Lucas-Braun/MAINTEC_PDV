<!-- =============================================
     FIORI DARK THEME - Paleta de Cores

     Baseado no SAP Fiori Horizon Dark.
     Para reutilizar: copie a pasta Themes/ inteira.
     ============================================= -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== BACKGROUND LAYERS ===== -->
    <Color x:Key="BackgroundColor">#111920</Color>
    <Color x:Key="ShellColor">#1A2733</Color>
    <Color x:Key="SurfaceColor">#243342</Color>
    <Color x:Key="SurfaceLightColor">#2C3E50</Color>

    <!-- ===== PRIMARY / BRAND ===== -->
    <Color x:Key="PrimaryColor">#4BA3F5</Color>
    <Color x:Key="PrimaryDarkColor">#2B7FD4</Color>
    <Color x:Key="PrimarySubtleColor">#1A3A5C</Color>

    <!-- ===== SEMANTIC ===== -->
    <Color x:Key="PositiveColor">#4CAF50</Color>
    <Color x:Key="NegativeColor">#EF5350</Color>
    <Color x:Key="CriticalColor">#FF9800</Color>
    <Color x:Key="NeutralColor">#78909C</Color>

    <!-- ===== TEXT ===== -->
    <Color x:Key="TextColor">#ECF0F4</Color>
    <Color x:Key="TextSecondaryColor">#7E91A5</Color>
    <Color x:Key="TextOnColorColor">#FFFFFF</Color>

    <!-- ===== BORDER ===== -->
    <Color x:Key="BorderColor">#344A5E</Color>
    <Color x:Key="SeparatorColor">#283848</Color>
    <Color x:Key="FocusColor">#4BA3F5</Color>

    <!-- ===================================================== -->
    <!-- BRUSHES (use estes nos controles via DynamicResource)  -->
    <!-- ===================================================== -->

    <!-- Background -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="ShellBrush" Color="{StaticResource ShellColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceLightBrush" Color="{StaticResource SurfaceLightColor}"/>

    <!-- Primary -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="PrimarySubtleBrush" Color="{StaticResource PrimarySubtleColor}"/>

    <!-- Semantic -->
    <SolidColorBrush x:Key="PositiveBrush" Color="{StaticResource PositiveColor}"/>
    <SolidColorBrush x:Key="NegativeBrush" Color="{StaticResource NegativeColor}"/>
    <SolidColorBrush x:Key="CriticalBrush" Color="{StaticResource CriticalColor}"/>
    <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource NeutralColor}"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextOnColorBrush" Color="{StaticResource TextOnColorColor}"/>

    <!-- Border -->
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource SeparatorColor}"/>
    <SolidColorBrush x:Key="FocusBrush" Color="{StaticResource FocusColor}"/>

    <!-- ===== THEME-SPECIFIC ===== -->
    <SolidColorBrush x:Key="RowHoverBrush" Color="#10FFFFFF"/>
    <SolidColorBrush x:Key="RowAlternateBrush" Color="#08FFFFFF"/>
    <SolidColorBrush x:Key="OverlaySuccessBrush" Color="#DD2E7D32"/>

    <!-- ===== EFFECTS ===== -->
    <DropShadowEffect x:Key="CardShadow"
                      BlurRadius="24"
                      ShadowDepth="4"
                      Opacity="0.4"
                      Color="#000000"/>

    <DropShadowEffect x:Key="CardShadowHover"
                      BlurRadius="32"
                      ShadowDepth="6"
                      Opacity="0.5"
                      Color="#000000"/>

</ResourceDictionary>
