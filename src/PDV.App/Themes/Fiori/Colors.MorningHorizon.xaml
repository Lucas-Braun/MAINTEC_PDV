<!-- =============================================
     FIORI MORNING HORIZON - Paleta de Cores (Light)

     Baseado no SAP Fiori Horizon (sap_horizon).
     Tema claro "branco e azul" clean.
     Mesmas keys do Colors.xaml — troca sem retrabalho.
     ============================================= -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== BACKGROUND LAYERS ===== -->
    <Color x:Key="BackgroundColor">#F5F6F7</Color>
    <Color x:Key="ShellColor">#FFFFFF</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceLightColor">#EFF1F2</Color>

    <!-- ===== PRIMARY / BRAND ===== -->
    <Color x:Key="PrimaryColor">#0070F2</Color>
    <Color x:Key="PrimaryDarkColor">#0054B6</Color>
    <Color x:Key="PrimarySubtleColor">#EBF8FF</Color>

    <!-- ===== SEMANTIC ===== -->
    <Color x:Key="PositiveColor">#256F3A</Color>
    <Color x:Key="NegativeColor">#AA0808</Color>
    <Color x:Key="CriticalColor">#E76500</Color>
    <Color x:Key="NeutralColor">#556B82</Color>

    <!-- ===== TEXT ===== -->
    <Color x:Key="TextColor">#131E29</Color>
    <Color x:Key="TextSecondaryColor">#556B82</Color>
    <Color x:Key="TextOnColorColor">#FFFFFF</Color>

    <!-- ===== BORDER ===== -->
    <Color x:Key="BorderColor">#D9D9D9</Color>
    <Color x:Key="SeparatorColor">#E5E5E5</Color>
    <Color x:Key="FocusColor">#0070F2</Color>

    <!-- ===================================================== -->
    <!-- BRUSHES (use estes nos controles via DynamicResource)  -->
    <!-- ===================================================== -->

    <!-- Background -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="ShellBrush" Color="{StaticResource ShellColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceLightBrush" Color="{StaticResource SurfaceLightColor}"/>

    <!-- Primary -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="PrimarySubtleBrush" Color="{StaticResource PrimarySubtleColor}"/>

    <!-- Semantic -->
    <SolidColorBrush x:Key="PositiveBrush" Color="{StaticResource PositiveColor}"/>
    <SolidColorBrush x:Key="NegativeBrush" Color="{StaticResource NegativeColor}"/>
    <SolidColorBrush x:Key="CriticalBrush" Color="{StaticResource CriticalColor}"/>
    <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource NeutralColor}"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextOnColorBrush" Color="{StaticResource TextOnColorColor}"/>

    <!-- Border -->
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource SeparatorColor}"/>
    <SolidColorBrush x:Key="FocusBrush" Color="{StaticResource FocusColor}"/>

    <!-- ===== THEME-SPECIFIC ===== -->
    <SolidColorBrush x:Key="RowHoverBrush" Color="#10000000"/>
    <SolidColorBrush x:Key="RowAlternateBrush" Color="#06000000"/>
    <SolidColorBrush x:Key="OverlaySuccessBrush" Color="#DD256F3A"/>

    <!-- ===== EFFECTS ===== -->
    <DropShadowEffect x:Key="CardShadow"
                      BlurRadius="16"
                      ShadowDepth="2"
                      Opacity="0.12"
                      Color="#000000"/>

    <DropShadowEffect x:Key="CardShadowHover"
                      BlurRadius="24"
                      ShadowDepth="4"
                      Opacity="0.18"
                      Color="#000000"/>

</ResourceDictionary>
