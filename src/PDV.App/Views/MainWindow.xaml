<Window x:Class="PDV.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PDV.App.ViewModels"
        xmlns:views="clr-namespace:PDV.App.Views"
        xmlns:controls="clr-namespace:PDV.App.Controls"
        Title="PDV - Ponto de Venda"
        WindowState="Maximized"
        WindowStyle="None"
        Background="{DynamicResource BackgroundBrush}"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PDVViewModel}">
            <views:PDVView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AberturaCaixaViewModel}">
            <views:AberturaCaixaView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PagamentoViewModel}">
            <views:PagamentoView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConsultaProdutoViewModel}">
            <views:ConsultaProdutoView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SangriaSuprimentoViewModel}">
            <views:SangriaSuprimentoView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FechamentoCaixaViewModel}">
            <views:FechamentoCaixaView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConfiguracoesViewModel}">
            <views:ConfiguracoesView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <!-- Conteudo troca automaticamente baseado no TelaAtual -->
        <controls:FadeContentControl Content="{Binding TelaAtual}"/>

        <!-- Botao fechar - fica POR CIMA de tudo -->
        <Button HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Width="46" Height="34"
                Margin="0,0,0,0"
                Panel.ZIndex="9999"
                Click="BtnFechar_Click"
                ToolTip="Fechar (Esc)"
                Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg"
                            Background="#30FFFFFF"
                            CornerRadius="0,0,0,6">
                        <TextBlock Text="X"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>

</Window>
