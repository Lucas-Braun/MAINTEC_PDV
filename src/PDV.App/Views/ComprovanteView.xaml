<UserControl x:Class="PDV.App.Views.ComprovanteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PDV.App.Converters"
             Background="{DynamicResource BackgroundBrush}"
             Focusable="True"
             Loaded="ComprovanteView_Loaded">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding VoltarParaPDVCommand}"/>
    </UserControl.InputBindings>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <!-- COLUNA ESQUERDA - Detalhes da venda -->
        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                CornerRadius="12" Margin="0,0,10,0"
                Effect="{DynamicResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header verde - VENDA FINALIZADA -->
                <Border Grid.Row="0" Background="{DynamicResource PositiveBrush}"
                        CornerRadius="12,12,0,0" Padding="24,18">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2713;" FontSize="28" FontWeight="Bold"
                                       Foreground="White" VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <TextBlock Text="VENDA FINALIZADA" FontSize="24" FontWeight="Bold"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Foreground="#DDFFFFFF" FontSize="14">
                                <Run Text="Venda #"/>
                                <Run Text="{Binding NumeroVenda, Mode=OneWay}" FontWeight="Bold"/>
                            </TextBlock>
                            <TextBlock Text="  |  " Foreground="#88FFFFFF" FontSize="14"/>
                            <TextBlock Text="{Binding DataVenda}" Foreground="#DDFFFFFF" FontSize="14"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Lista de itens -->
                <Grid Grid.Row="1" Margin="20,16,20,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="ITENS DA VENDA"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <Border Grid.Row="1" Background="{DynamicResource SurfaceLightBrush}"
                            CornerRadius="8" Padding="4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Itens}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12,8" Margin="0,0,0,1"
                                                BorderBrush="{DynamicResource SeparatorBrush}"
                                                BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="35"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Column="0" Grid.RowSpan="2"
                                                           Text="{Binding NumeroItem, StringFormat='{}{0:D3}'}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="12" FontFamily="Consolas"
                                                           VerticalAlignment="Center"/>

                                                <TextBlock Grid.Column="1" Grid.Row="0"
                                                           Text="{Binding DescricaoProduto}"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <TextBlock Grid.Column="1" Grid.Row="1"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="12" Margin="0,2,0,0">
                                                    <Run Text="{Binding Quantidade, StringFormat=N2, Mode=OneWay}"/>
                                                    <Run Text=" x "/>
                                                    <Run Text="{Binding PrecoUnitario, StringFormat=C2, Mode=OneWay}"/>
                                                </TextBlock>

                                                <TextBlock Grid.Column="2" Grid.RowSpan="2"
                                                           Text="{Binding ValorTotal, StringFormat=C2}"
                                                           Foreground="{DynamicResource PositiveBrush}"
                                                           FontSize="14" FontWeight="Bold"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Totais -->
                <Border Grid.Row="2" Padding="20,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Subtotal:"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="14"/>
                            <TextBlock Text="{Binding SubTotal, StringFormat=C2}"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="Desconto:"
                                       Foreground="{DynamicResource NegativeBrush}"
                                       FontSize="14"/>
                            <TextBlock Text="{Binding DescontoTotal, StringFormat=C2}"
                                       Foreground="{DynamicResource NegativeBrush}"
                                       FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                        <Separator Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,10"/>
                        <Border Background="{DynamicResource PrimarySubtleBrush}"
                                CornerRadius="10" Padding="16,12">
                            <Grid>
                                <TextBlock Text="TOTAL"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="14" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="R$ "
                                               Foreground="{DynamicResource PositiveBrush}"
                                               FontSize="18" VerticalAlignment="Bottom"
                                               Margin="0,0,0,3"/>
                                    <TextBlock Text="{Binding ValorTotal, StringFormat=N2}"
                                               Foreground="{DynamicResource PositiveBrush}"
                                               FontSize="32" FontWeight="ExtraBold"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- COLUNA DIREITA - NFC-e, Pagamentos, Acoes -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Banner contingencia -->
            <Border Grid.Row="0" Background="#FFA000" CornerRadius="8"
                    Padding="14,10" Margin="0,0,0,10"
                    Visibility="{Binding EmContingencia, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets"
                               FontSize="16" Foreground="White"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="NFC-e em contingencia" FontSize="13"
                               FontWeight="Bold" Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Dados NFC-e -->
            <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="12" Padding="20" Margin="0,0,0,10"
                    Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="NFC-e" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Status:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13"/>
                        <TextBlock Text="{Binding StatusNFCe}"
                                   FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Right">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource PositiveBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding EmContingencia}" Value="True">
                                            <Setter Property="Foreground" Value="#FFA000"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Numero:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13"/>
                        <TextBlock Text="{Binding NumeroNFCe}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="13" FontWeight="SemiBold"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Chave de acesso:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ChaveNFCe}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="11" FontFamily="Consolas"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Protocolo:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ProtocoloAutorizacao}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="11" FontFamily="Consolas"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Pagamentos -->
            <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="12" Padding="20" Margin="0,0,0,10"
                    Effect="{DynamicResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="PAGAMENTOS"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11" FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding PagamentosLista}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceLightBrush}"
                                        CornerRadius="8" Padding="12,10" Margin="0,0,0,6">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="{Binding FormaPagamento}"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Valor, StringFormat=C2}"
                                                       Foreground="{DynamicResource PositiveBrush}"
                                                       FontSize="14" FontWeight="Bold"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>

                                        <!-- Valor recebido e troco (dinheiro) -->
                                        <StackPanel Margin="0,4,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FormaPagamento}" Value="Dinheiro">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Grid>
                                                <TextBlock Text="Recebido:"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="11"/>
                                                <TextBlock Text="{Binding ValorRecebido, StringFormat=C2}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="11" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid>
                                                <TextBlock Text="Troco:"
                                                           Foreground="{DynamicResource CriticalBrush}"
                                                           FontSize="11"/>
                                                <TextBlock Text="{Binding Troco, StringFormat=C2}"
                                                           Foreground="{DynamicResource CriticalBrush}"
                                                           FontSize="11" FontWeight="Bold"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>

                                        <!-- NSU e bandeira (cartao) -->
                                        <StackPanel Margin="0,4,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FormaPagamento}" Value="CartaoCredito">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FormaPagamento}" Value="CartaoDebito">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Grid>
                                                <TextBlock Text="Bandeira:"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="11"/>
                                                <TextBlock Text="{Binding BandeiraCartao}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="11" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid>
                                                <TextBlock Text="NSU:"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="11"/>
                                                <TextBlock Text="{Binding NSU}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="11" FontFamily="Consolas"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- Botoes -->
            <StackPanel Grid.Row="3">
                <Button Content="REIMPRIMIR CUPOM"
                        Command="{Binding ReimprimirCommand}"
                        Style="{DynamicResource BotaoPDV}"
                        FontSize="14" Height="44"
                        Margin="0,0,0,8"/>

                <Button Content="NOVA VENDA (ESC)"
                        Command="{Binding VoltarParaPDVCommand}"
                        Style="{DynamicResource BotaoPositive}"
                        FontSize="16" Height="48"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
