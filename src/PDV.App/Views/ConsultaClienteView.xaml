<UserControl x:Class="PDV.App.Views.ConsultaClienteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding VoltarCommand}"/>
    </UserControl.InputBindings>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============================================= -->
        <!-- BUSCA                                         -->
        <!-- ============================================= -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                CornerRadius="12" Padding="20" Margin="0,0,0,10"
                Effect="{DynamicResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="CONSULTA DE CLIENTE"
                           Style="{DynamicResource TituloPDV}"
                           FontSize="22"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>

                <TextBox Grid.Column="1"
                         Text="{Binding TermoBusca, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource TextBoxPDV}"
                         FontSize="18" Padding="12,10"
                         x:Name="TxtBusca">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding PesquisarCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <Button Grid.Column="2" Content="PESQUISAR"
                        Command="{Binding PesquisarCommand}"
                        Style="{DynamicResource BotaoPDV}"
                        FontSize="14" Height="42"
                        Margin="10,0,0,0"
                        IsEnabled="{Binding Processando, Converter={StaticResource InvertBool}}"/>
            </Grid>
        </Border>

        <!-- ============================================= -->
        <!-- GRID DE RESULTADOS                            -->
        <!-- ============================================= -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}"
                CornerRadius="12" Padding="0" Margin="0,0,0,10"
                Effect="{DynamicResource CardShadow}">
            <DataGrid ItemsSource="{Binding Clientes}"
                      SelectedItem="{Binding ClienteSelecionado}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Style="{DynamicResource DataGridPDV}">
                <DataGrid.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding SelecionarCommand}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="CODIGO" Width="80"
                        Binding="{Binding Id}"/>
                    <DataGridTextColumn Header="NOME" Width="*"
                        Binding="{Binding Nome}"/>
                    <DataGridTextColumn Header="CPF/CNPJ" Width="160"
                        Binding="{Binding CpfCnpj}"/>
                    <DataGridTextColumn Header="TELEFONE" Width="150"
                        Binding="{Binding Telefone}"/>
                    <DataGridTextColumn Header="EMAIL" Width="200"
                        Binding="{Binding Email}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ============================================= -->
        <!-- CADASTRO RAPIDO                               -->
        <!-- ============================================= -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}"
                CornerRadius="12" Padding="20" Margin="0,0,0,10"
                Effect="{DynamicResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="CADASTRO RAPIDO"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="13" FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Nome:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource TextBoxPDV}"
                                 FontSize="14" Padding="8,8"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="CPF/CNPJ:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding CpfCnpj, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource TextBoxPDV}"
                                 FontSize="14" Padding="8,8"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="Telefone:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Telefone, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource TextBoxPDV}"
                                 FontSize="14" Padding="8,8"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="0,0,10,0">
                        <TextBlock Text="Email:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource TextBoxPDV}"
                                 FontSize="14" Padding="8,8"/>
                    </StackPanel>

                    <Button Grid.Column="4" Content="CADASTRAR"
                            Command="{Binding CadastrarCommand}"
                            Style="{DynamicResource BotaoPDV}"
                            FontSize="14" Height="42"
                            VerticalAlignment="Bottom"
                            IsEnabled="{Binding Processando, Converter={StaticResource InvertBool}}"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ============================================= -->
        <!-- BOTOES + MENSAGENS                            -->
        <!-- ============================================= -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Loading / Erro / Sucesso -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Pesquisando..."
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Visibility="{Binding Processando, Converter={StaticResource BoolToVisibility}}"/>
                <TextBox Text="{Binding MensagemErro, Mode=OneWay}"
                         Foreground="{DynamicResource NegativeBrush}"
                         FontSize="13" IsReadOnly="True"
                         BorderThickness="0" Background="Transparent"
                         TextWrapping="Wrap"
                         Visibility="{Binding MensagemErro, Converter={StaticResource StringToVisibility}}"/>
                <TextBlock Text="{Binding MensagemSucesso}"
                           Foreground="{DynamicResource PositiveBrush}"
                           FontSize="13"
                           Visibility="{Binding MensagemSucesso, Converter={StaticResource StringToVisibility}}"/>
            </StackPanel>

            <Button Grid.Column="1" Content="VOLTAR (ESC)"
                    Command="{Binding VoltarCommand}"
                    Style="{DynamicResource BotaoNeutral}"
                    FontSize="14" Height="48"
                    Margin="0,0,10,0"/>

            <Button Grid.Column="2" Content="LIMPAR CLIENTE"
                    Command="{Binding LimparClienteCommand}"
                    Style="{DynamicResource BotaoNeutral}"
                    FontSize="14" Height="48"
                    Margin="0,0,10,0"/>

            <Button Grid.Column="3" Content="SELECIONAR"
                    Command="{Binding SelecionarCommand}"
                    Style="{DynamicResource BotaoPositive}"
                    FontSize="14" Height="48"/>
        </Grid>
    </Grid>

</UserControl>
