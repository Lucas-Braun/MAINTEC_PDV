<UserControl x:Class="PDV.App.Views.ConfiguracoesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding VoltarAoPDVCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <!-- Card central -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="500"
                Background="{DynamicResource SurfaceBrush}"
                CornerRadius="12"
                Padding="40,36"
                Effect="{DynamicResource CardShadow}">

            <StackPanel>
                <!-- Titulo -->
                <TextBlock Text="CONFIGURACOES"
                           Style="{DynamicResource TituloPDV}"
                           FontSize="28"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28"/>

                <!-- ====== SECAO TEMA ====== -->
                <TextBlock Text="TEMA"
                           Style="{DynamicResource LabelPDV}"
                           Margin="0,0,0,10"/>

                <Border Background="{DynamicResource SurfaceLightBrush}"
                        CornerRadius="8"
                        Padding="16,12"
                        Margin="0,0,0,24">
                    <StackPanel>
                        <RadioButton Style="{DynamicResource RadioPDV}"
                                     Content="Morning Horizon (Light)"
                                     GroupName="Tema"
                                     IsChecked="{Binding IsMorningHorizon, Mode=TwoWay}"
                                     Margin="0,0,0,8"/>
                        <RadioButton Style="{DynamicResource RadioPDV}"
                                     Content="Evening Horizon (Dark)"
                                     GroupName="Tema"
                                     IsChecked="{Binding IsEveningHorizon, Mode=TwoWay}"/>
                    </StackPanel>
                </Border>

                <!-- ====== SECAO SISTEMA ====== -->
                <TextBlock Text="SISTEMA"
                           Style="{DynamicResource LabelPDV}"
                           Margin="0,0,0,10"/>

                <Border Background="{DynamicResource SurfaceLightBrush}"
                        CornerRadius="8"
                        Padding="16,12"
                        Margin="0,0,0,28">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Empresa -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Empresa:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13" Margin="0,0,12,8"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding NomeEmpresa}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,0,8"/>

                        <!-- CNPJ -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="CNPJ:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13" Margin="0,0,12,8"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding CnpjEmpresa}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,0,8"/>

                        <!-- Endereco -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Endereco:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13" Margin="0,0,12,8"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding EnderecoEmpresa}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="13" FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" Margin="0,0,0,8"/>

                        <!-- Impressora -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Impressora:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13" Margin="0,0,12,8"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{Binding Impressora}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,0,8"/>

                        <!-- Versao -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Versao:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13" Margin="0,0,12,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="1"
                                   Text="{Binding VersaoApp}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Botao Voltar -->
                <Button Content="VOLTAR (ESC)"
                        Command="{Binding VoltarAoPDVCommand}"
                        Style="{DynamicResource BotaoNeutral}"
                        FontSize="16"
                        Height="48"/>
            </StackPanel>
        </Border>
    </Grid>

</UserControl>
