<UserControl x:Class="PDV.App.Views.ConfiguracoesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding VoltarAoPDVCommand}" />
    </UserControl.InputBindings>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============================================= -->
        <!-- TITULO                                        -->
        <!-- ============================================= -->
        <TextBlock Grid.Row="0" Text="CONFIGURACOES"
                   Style="{DynamicResource TituloPDV}"
                   FontSize="24"
                   Margin="0,0,0,16"/>

        <!-- ============================================= -->
        <!-- GRID PRINCIPAL - 2 COLUNAS                    -->
        <!-- ============================================= -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ====== COLUNA ESQUERDA: IMPRESSORA ====== -->
            <Border Grid.Column="0" Grid.Row="0"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="12" Padding="24,20"
                    Effect="{DynamicResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="IMPRESSORA"
                               Style="{DynamicResource LabelPDV}"
                               FontSize="15" Margin="0,0,0,16"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Tipo Conexao -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Tipo:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13" VerticalAlignment="Center"
                                   Margin="0,0,12,12"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                  Style="{DynamicResource ComboBoxPDV}"
                                  ItemsSource="{Binding TiposConexao}"
                                  SelectedItem="{Binding TipoConexao}"
                                  Margin="0,0,0,12"/>

                        <!-- Porta COM (visivel quando USB/Serial) -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Porta:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13" VerticalAlignment="Center"
                                   Margin="0,0,12,12"
                                   Visibility="{Binding IsConexaoSerial, Converter={StaticResource BoolToVisibility}}"/>
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  Style="{DynamicResource ComboBoxPDV}"
                                  ItemsSource="{Binding PortasDisponiveis}"
                                  SelectedItem="{Binding PortaSelecionada}"
                                  Margin="0,0,8,12"
                                  Visibility="{Binding IsConexaoSerial, Converter={StaticResource BoolToVisibility}}"/>
                        <Button Grid.Row="1" Grid.Column="2"
                                Content="ATUALIZAR"
                                Command="{Binding AtualizarPortasCommand}"
                                Style="{DynamicResource BotaoGhost}"
                                FontSize="12" Padding="12,6"
                                Margin="0,0,0,12"
                                Visibility="{Binding IsConexaoSerial, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Impressora Windows (visivel quando Spooler) -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Impressora:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13" VerticalAlignment="Center"
                                   Margin="0,0,12,12"
                                   Visibility="{Binding IsConexaoSpooler, Converter={StaticResource BoolToVisibility}}"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                  Style="{DynamicResource ComboBoxPDV}"
                                  ItemsSource="{Binding ImpressorasWindows}"
                                  SelectedItem="{Binding ImpressoraSelecionada}"
                                  Margin="0,0,0,12"
                                  Visibility="{Binding IsConexaoSpooler, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- IP (visivel quando Rede) -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="IP:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13" VerticalAlignment="Center"
                                   Margin="0,0,12,12"
                                   Visibility="{Binding IsConexaoRede, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                 Style="{DynamicResource TextBoxPDV}"
                                 Text="{Binding IpImpressora, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"
                                 Visibility="{Binding IsConexaoRede, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Porta Rede (visivel quando Rede) -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Porta:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13" VerticalAlignment="Center"
                                   Margin="0,0,12,12"
                                   Visibility="{Binding IsConexaoRede, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                 Style="{DynamicResource TextBoxPDV}"
                                 Text="{Binding PortaRede, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"
                                 Visibility="{Binding IsConexaoRede, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Colunas -->
                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Text="Colunas:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13" VerticalAlignment="Center"
                                   Margin="0,0,12,12"/>
                        <ComboBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                                  Style="{DynamicResource ComboBoxPDV}"
                                  ItemsSource="{Binding OpcoesColuna}"
                                  SelectedItem="{Binding ColunasMaximas}"
                                  Margin="0,0,0,12"/>

                        <!-- Testar conexao -->
                        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                                    Orientation="Horizontal"
                                    Margin="0,4,0,0">
                            <Button Content="TESTAR CONEXAO"
                                    Command="{Binding TestarConexaoCommand}"
                                    Style="{DynamicResource BotaoGhost}"
                                    FontSize="13" Padding="16,8"/>
                            <Button Content="IMPRIMIR TESTE"
                                    Command="{Binding ImprimirTesteCommand}"
                                    Style="{DynamicResource BotaoPDV}"
                                    FontSize="13" Padding="16,8"
                                    Margin="8,0,0,0"/>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="16,0,0,0"
                                        Visibility="{Binding TesteVisivel, Converter={StaticResource BoolToVisibility}}">
                                <Ellipse Width="8" Height="8"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{DynamicResource NegativeBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TesteConectado}" Value="True">
                                                    <Setter Property="Fill" Value="{DynamicResource PositiveBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding ResultadoTeste}"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ====== COLUNA DIREITA: TEMA + API + SISTEMA ====== -->
            <Grid Grid.Column="2" Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- TEMA -->
                <Border Grid.Row="0"
                        Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="12" Padding="24,20"
                        Effect="{DynamicResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="TEMA"
                                   Style="{DynamicResource LabelPDV}"
                                   FontSize="15" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Style="{DynamicResource RadioPDV}"
                                         Content="Morning Horizon (Light)"
                                         GroupName="Tema"
                                         IsChecked="{Binding IsMorningHorizon, Mode=TwoWay}"
                                         Margin="0,0,20,0"/>
                            <RadioButton Style="{DynamicResource RadioPDV}"
                                         Content="Evening Horizon (Dark)"
                                         GroupName="Tema"
                                         IsChecked="{Binding IsEveningHorizon, Mode=TwoWay}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- API -->
                <Border Grid.Row="2"
                        Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="12" Padding="24,20"
                        Effect="{DynamicResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="API"
                                   Style="{DynamicResource LabelPDV}"
                                   FontSize="15" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="URL:"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13" VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <TextBox Grid.Column="1"
                                     Style="{DynamicResource TextBoxPDV}"
                                     Text="{Binding ApiUrl, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- SISTEMA -->
                <Border Grid.Row="4"
                        Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="12" Padding="24,20"
                        Effect="{DynamicResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="SISTEMA"
                                   Style="{DynamicResource LabelPDV}"
                                   FontSize="15" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Empresa:"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13" Margin="0,0,12,8"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding NomeEmpresa}"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="CNPJ:"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13" Margin="0,0,12,8"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding CnpjEmpresa}"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Endereco:"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13" Margin="0,0,12,8"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding EnderecoEmpresa}"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="13" FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Versao:"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13" Margin="0,0,12,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                       Text="{Binding VersaoApp}"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ============================================= -->
        <!-- RODAPE - SALVAR + VOLTAR                      -->
        <!-- ============================================= -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Feedback -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Visibility="{Binding TesteVisivel, Converter={StaticResource BoolToVisibility}}">
                <Ellipse Width="8" Height="8"
                         VerticalAlignment="Center"
                         Margin="0,0,6,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{DynamicResource NegativeBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TesteConectado}" Value="True">
                                    <Setter Property="Fill" Value="{DynamicResource PositiveBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding ResultadoTeste}"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="SALVAR"
                    Command="{Binding SalvarCommand}"
                    Style="{DynamicResource BotaoPositive}"
                    FontSize="16" Height="48"
                    Padding="40,0"/>
            <Button Grid.Column="3"
                    Content="VOLTAR (ESC)"
                    Command="{Binding VoltarAoPDVCommand}"
                    Style="{DynamicResource BotaoNeutral}"
                    FontSize="16" Height="48"
                    Padding="40,0"/>
        </Grid>
    </Grid>

</UserControl>
