                                        <TextBlock Text="&#xE748;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="18" HorizontalAlignment="Center"/>
                                        <TextBlock Text="LOGOUT" FontSize="11" FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="F11" FontSize="9" Opacity="0.6"
                                                   HorizontalAlignment="Center"/>
