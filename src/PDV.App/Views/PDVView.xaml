<!-- =============================================
     PDV.App/Views/PDVView.xaml
     Tela principal do caixa - Tema Fiori
     ============================================= -->
<UserControl x:Class="PDV.App.Views.PDVView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="768" d:DesignWidth="1366"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.InputBindings>
        <KeyBinding Key="F2" Command="{Binding FinalizarVendaCommand}" />
        <KeyBinding Key="F3" Command="{Binding ConsultarClienteCommand}" />
        <KeyBinding Key="F4" Command="{Binding ConsultarProdutoCommand}" />
        <KeyBinding Key="F5" Command="{Binding RealizarSangriaCommand}" />
        <KeyBinding Key="F6" Command="{Binding RealizarSuprimentoCommand}" />
        <KeyBinding Key="F7" Command="{Binding ConsultarVendasCommand}" />
        <KeyBinding Key="F9" Command="{Binding CancelarVendaCommand}" />
        <KeyBinding Key="F10" Command="{Binding AbrirConfiguracoesCommand}" />
        <KeyBinding Key="F12" Command="{Binding FecharCaixaCommand}" />
        <KeyBinding Key="Delete" Command="{Binding RemoverItemCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <!-- ============================================= -->
        <!-- HEADER                                        -->
        <!-- ============================================= -->
        <Border Grid.Row="0" Background="{DynamicResource ShellBrush}"
                BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="MEINTEC" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,20,0">
                        <Run Text="Caixa: " />
                        <Run Text="{Binding NumeroCaixa, Mode=OneWay}" FontWeight="Bold"
                             Foreground="{DynamicResource TextBrush}" />
                    </TextBlock>
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,20,0">
                        <Run Text="Operador: " />
                        <Run Text="{Binding MensagemOperador}" FontWeight="Bold"
                             Foreground="{DynamicResource TextBrush}" />
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center" Margin="0,0,20,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ClienteDefinido}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="Cliente: " Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <Run Text="{Binding NomeCliente, Mode=OneWay}" FontWeight="Bold"
                             Foreground="{DynamicResource PositiveBrush}"/>
                        <Run Text=" (" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <Run Text="{Binding CpfCliente, Mode=OneWay}"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <Run Text=")" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding DataHoraAtual}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               FontFamily="Consolas"
                               FontSize="13" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================= -->
        <!-- CONTEUDO PRINCIPAL                             -->
        <!-- ============================================= -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!-- PAINEL ESQUERDO - Itens da venda -->
            <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="12" Margin="0,0,10,0" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Campo de leitura do codigo de barras -->
                    <Border Grid.Row="0" Background="{DynamicResource SurfaceLightBrush}"
                            CornerRadius="12,12,0,0" Padding="15,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Codigo:"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" FontSize="14" />

                            <TextBox Grid.Column="1"
                                     Text="{Binding CodigoBarrasInput, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="18" FontWeight="Bold"
                                     Background="Transparent"
                                     Foreground="{DynamicResource TextBrush}"
                                     BorderBrush="{DynamicResource PrimaryBrush}"
                                     BorderThickness="0,0,0,2"
                                     Padding="8,5"
                                     CaretBrush="{DynamicResource TextBrush}"
                                     VerticalContentAlignment="Center"
                                     x:Name="TxtCodigoBarras">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter"
                                                Command="{Binding AdicionarProdutoCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>

                            <TextBlock Grid.Column="2" Text="Qtd:"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" FontSize="14"
                                       Margin="15,0,5,0" />

                            <TextBox Grid.Column="3" Width="70"
                                     Text="{Binding QuantidadeInput, StringFormat=N2}"
                                     FontSize="16" FontWeight="Bold"
                                     Background="Transparent"
                                     Foreground="{DynamicResource TextBrush}"
                                     BorderBrush="{DynamicResource PrimaryBrush}"
                                     BorderThickness="0,0,0,2"
                                     Padding="8,5"
                                     CaretBrush="{DynamicResource TextBrush}"
                                     TextAlignment="Center"
                                     VerticalContentAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Grid de itens da venda -->
                    <Grid Grid.Row="1">
                        <DataGrid ItemsSource="{Binding Itens}"
                                  SelectedItem="{Binding ItemSelecionado}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserSortColumns="False"
                                  CellEditEnding="DataGrid_CellEditEnding"
                                  Style="{DynamicResource DataGridPDV}">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Width="45"
                                    Binding="{Binding NumeroItem}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="CODIGO" Width="130"
                                    Binding="{Binding CodigoBarras}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="DESCRICAO" Width="*"
                                    Binding="{Binding DescricaoProduto}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="UN" Width="50"
                                    Binding="{Binding UnidadeMedida}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="QTD" Width="70"
                                    Binding="{Binding Quantidade, StringFormat=N2}">
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceLightBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="SelectionBrush" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="4,2"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="VL. UNIT." Width="100"
                                    Binding="{Binding PrecoUnitario, StringFormat=C2}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="DESCONTO" Width="90"
                                    Binding="{Binding DescontoValor, StringFormat=C2}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="TOTAL" Width="110"
                                    Binding="{Binding ValorTotal, StringFormat=C2}" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold" />
                                            <Setter Property="Foreground"
                                                    Value="{DynamicResource PositiveBrush}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Empty state -->
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding VendaEmAndamento}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="&#xE8A5;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="48"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       Opacity="0.4"
                                       Margin="0,0,0,16"/>
                            <TextBlock Text="Leia um codigo de barras para iniciar"
                                       FontSize="16"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       Opacity="0.6"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- PAINEL LATERAL DIREITO - Totais e Acoes -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Ultimo item adicionado -->
                <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="12" Padding="20" Margin="0,0,0,10">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding UltimoItemDescricao}" Value="">
                                    <Setter Property="Opacity" Value="0.5" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="ULTIMO ITEM"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="1"
                                   Text="{Binding UltimoItemDescricao}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="14" FontWeight="Bold"
                                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                   MaxHeight="40"
                                   Margin="0,6,0,0" />

                        <TextBlock Grid.Row="2"
                                   Text="{Binding UltimoItemQtd}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="12"
                                   Margin="0,2,0,0" />

                        <TextBlock Grid.Row="3"
                                   Text="{Binding UltimoItemPreco}"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   FontSize="28" FontWeight="ExtraBold"
                                   HorizontalAlignment="Right"
                                   Margin="0,4,0,0" />
                    </Grid>
                </Border>

                <!-- Totais -->
                <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="12" Padding="20" Margin="0,0,0,10">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Subtotal:"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="14" />
                            <TextBlock Text="{Binding SubTotal, StringFormat=C2}"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Right" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Desconto:"
                                       Foreground="{DynamicResource NegativeBrush}"
                                       FontSize="14" />
                            <TextBlock Text="{Binding DescontoTotal, StringFormat=C2}"
                                       Foreground="{DynamicResource NegativeBrush}"
                                       FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Right" />
                        </Grid>

                        <Separator Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,0" />

                        <!-- Total da venda - destaque grande -->
                        <Border Background="{DynamicResource PrimarySubtleBrush}"
                                CornerRadius="10" Padding="16,14" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="TOTAL DA VENDA"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11" FontWeight="SemiBold" />

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                            HorizontalAlignment="Right">
                                    <TextBlock Text="R$ "
                                               Foreground="{DynamicResource PositiveBrush}"
                                               FontSize="22" FontWeight="Normal"
                                               VerticalAlignment="Bottom" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding ValorTotal, StringFormat=N2}"
                                               Foreground="{DynamicResource PositiveBrush}"
                                               FontSize="42" FontWeight="ExtraBold" />
                                </StackPanel>

                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12" Margin="0,4,0,0">
                                    <Run Text="{Binding TotalItens, Mode=OneWay}" />
                                    <Run Text=" itens" />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Botoes de funcao -->
                <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="12" Padding="10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <WrapPanel>
                            <Button Style="{DynamicResource BotaoFuncao}"
                                    Background="{DynamicResource PositiveBrush}"
                                    Command="{Binding FinalizarVendaCommand}"
                                    ToolTip="Finalizar venda e ir para pagamento (F2)">
                                <StackPanel>
                                    <TextBlock Text="PAGAMENTO" FontSize="14" FontWeight="Bold" />
                                    <TextBlock Text="F2" FontSize="10" Opacity="0.7"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Style="{DynamicResource BotaoFuncao}"
                                    Background="{DynamicResource PrimaryBrush}"
                                    Command="{Binding ConsultarClienteCommand}"
                                    ToolTip="Consultar ou cadastrar cliente (F3)">
                                <StackPanel>
                                    <TextBlock Text="CLIENTE" FontSize="14" FontWeight="Bold" />
                                    <TextBlock Text="F3" FontSize="10" Opacity="0.7"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Style="{DynamicResource BotaoFuncao}"
                                    Background="{DynamicResource PrimaryBrush}"
                                    Command="{Binding ConsultarProdutoCommand}"
                                    ToolTip="Consultar produto por nome ou codigo (F4)">
                                <StackPanel>
                                    <TextBlock Text="CONSULTA" FontSize="14" FontWeight="Bold" />
                                    <TextBlock Text="F4" FontSize="10" Opacity="0.7"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Style="{DynamicResource BotaoFuncao}"
                                    Background="{DynamicResource CriticalBrush}"
                                    Command="{Binding RealizarSangriaCommand}"
                                    ToolTip="Retirar dinheiro do caixa (F5)">
                                <StackPanel>
                                    <TextBlock Text="SANGRIA" FontSize="14" FontWeight="Bold" />
                                    <TextBlock Text="F5" FontSize="10" Opacity="0.7"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Style="{DynamicResource BotaoFuncao}"
                                    Background="{DynamicResource PrimaryBrush}"
                                    Command="{Binding RealizarSuprimentoCommand}"
                                    ToolTip="Adicionar dinheiro ao caixa (F6)">
                                <StackPanel>
                                    <TextBlock Text="SUPRIMENTO" FontSize="14" FontWeight="Bold" />
                                    <TextBlock Text="F6" FontSize="10" Opacity="0.7"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Style="{DynamicResource BotaoFuncao}"
                                    Background="{DynamicResource PrimaryBrush}"
                                    Command="{Binding ConsultarVendasCommand}"
                                    ToolTip="Consultar vendas realizadas (F7)">
                                <StackPanel>
                                    <TextBlock Text="VENDAS" FontSize="14" FontWeight="Bold" />
                                    <TextBlock Text="F7" FontSize="10" Opacity="0.7"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Style="{DynamicResource BotaoFuncao}"
                                    Background="{DynamicResource NegativeBrush}"
                                    Command="{Binding CancelarVendaCommand}"
                                    ToolTip="Cancelar a venda atual (F9)">
                                <StackPanel>
                                    <TextBlock Text="CANCELAR" FontSize="14" FontWeight="Bold" />
                                    <TextBlock Text="F9" FontSize="10" Opacity="0.7"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Style="{DynamicResource BotaoFuncao}"
                                    Background="{DynamicResource NeutralBrush}"
                                    Command="{Binding AbrirConfiguracoesCommand}"
                                    ToolTip="Configuracoes do sistema (F10)">
                                <StackPanel>
                                    <TextBlock Text="CONFIG" FontSize="14" FontWeight="Bold" />
                                    <TextBlock Text="F10" FontSize="10" Opacity="0.7"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Style="{DynamicResource BotaoFuncao}"
                                    Background="{DynamicResource NeutralBrush}"
                                    Command="{Binding FecharCaixaCommand}"
                                    ToolTip="Fechar o caixa e gerar relatorio (F12)">
                                <StackPanel>
                                    <TextBlock Text="FECHAR CAIXA" FontSize="14" FontWeight="Bold" />
                                    <TextBlock Text="F12" FontSize="10" Opacity="0.7"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- ============================================= -->
        <!-- STATUS BAR                                     -->
        <!-- ============================================= -->
        <Border Grid.Row="2" Background="{DynamicResource ShellBrush}"
                BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding MensagemStatus}"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center" FontSize="13" />

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="20,0">
                    <Ellipse Width="8" Height="8" Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource NegativeBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NfceOnline}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource PositiveBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusNfceTexto}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="20,0">
                    <Ellipse Width="8" Height="8" Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource NegativeBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TefConectado}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource PositiveBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusTefTexto}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12" />
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource NegativeBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ApiConectada}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource PositiveBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusApiTexto}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================= -->
        <!-- OVERLAY DE CONFIRMACAO CANCELAMENTO           -->
        <!-- ============================================= -->
        <Grid Grid.RowSpan="3" Panel.ZIndex="80">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ConfirmandoCancelamento}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="#88000000"/>
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="16"
                    Padding="40,30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{DynamicResource CardShadow}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="CANCELAR VENDA?"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource NegativeBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Todos os itens serao removidos."
                               FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,24"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button Content="SIM, CANCELAR (F9)"
                                Command="{Binding CancelarVendaCommand}"
                                Style="{DynamicResource BotaoNegative}"
                                FontSize="14" Height="44"
                                Padding="24,0"
                                Margin="0,0,12,0"/>
                        <Button Content="NAO, VOLTAR (ESC)"
                                Command="{Binding DesistirCancelamentoCommand}"
                                Style="{DynamicResource BotaoNeutral}"
                                FontSize="14" Height="44"
                                Padding="24,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ============================================= -->
        <!-- OVERLAY DE PROCESSAMENTO                      -->
        <!-- ============================================= -->
        <Grid Grid.RowSpan="3" Panel.ZIndex="90">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Processando}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="#88000000"/>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="200" Height="4"
                             Foreground="{DynamicResource PrimaryBrush}"
                             Background="{DynamicResource SurfaceLightBrush}"
                             BorderThickness="0"/>
                <TextBlock Text="Processando..."
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
