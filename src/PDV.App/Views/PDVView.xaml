                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="F10" FontSize="9" Opacity="0.6"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{DynamicResource BotaoFuncao}"
                                        Background="{DynamicResource NeutralBrush}"
                                        Command="{Binding TrocarOperadorCommand}"
                                        ToolTip="Trocar operador / Logout (F11)">
