                                        <TextBlock Text="LEITURA X" FontSize="11" FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{DynamicResource BotaoFuncao}"
                                        Background="{DynamicResource NeutralBrush}"
