                                               Foreground="{DynamicResource PrimaryBrush}" FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="Pagamento" FontSize="13"
                                           Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="4"
                                        Padding="6,3" HorizontalAlignment="Left">
                                    <TextBlock Text="F8" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}" FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="Desconto" FontSize="13"
                                           Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="4"
                                        Padding="6,3" HorizontalAlignment="Left">
                                    <TextBlock Text="F9" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}" FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="Cancelar venda" FontSize="13"
                                           Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="4"
                                        Padding="6,3" HorizontalAlignment="Left">
                                    <TextBlock Text="F1" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}" FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="Repetir item" FontSize="13"
                                           Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <Separator Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>

                            <TextBlock Text="CONSULTAS" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,6" Opacity="0.6"/>
                            <Grid Margin="0,0,0,4">
                                <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="4"
                                        Padding="6,3" HorizontalAlignment="Left">
                                    <TextBlock Text="F3" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}" FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="Cliente" FontSize="13"
                                           Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="4"
                                        Padding="6,3" HorizontalAlignment="Left">
                                    <TextBlock Text="F4" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}" FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="Produto" FontSize="13"
                                           Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="4"
                                        Padding="6,3" HorizontalAlignment="Left">
                                    <TextBlock Text="F7" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}" FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="Vendas" FontSize="13"
                                           Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <!-- Coluna Direita -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="CAIXA" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,6" Opacity="0.6"/>
                            <Grid Margin="0,0,0,4">
                                <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="4"
                                        Padding="6,3" HorizontalAlignment="Left">
                                    <TextBlock Text="F5" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}" FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="Sangria" FontSize="13"
                                           Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="4"
                                        Padding="6,3" HorizontalAlignment="Left">
                                    <TextBlock Text="F6" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}" FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="Suprimento" FontSize="13"
                                           Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="4"
                                        Padding="6,3" HorizontalAlignment="Left">
                                    <TextBlock Text="F12" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}" FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="Fechar caixa" FontSize="13"
                                           Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <Separator Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>

                            <TextBlock Text="EDICAO" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,6" Opacity="0.6"/>
                            <Grid Margin="0,0,0,4">
                                <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="4"
                                        Padding="6,3" HorizontalAlignment="Left">
                                    <TextBlock Text="DEL" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}" FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="Remover item" FontSize="13"
                                           Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="4"
                                        Padding="6,3" HorizontalAlignment="Left">
                                    <TextBlock Text=" + " FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}" FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="Aumentar qtd" FontSize="13"
                                           Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="4"
                                        Padding="6,3" HorizontalAlignment="Left">
                                    <TextBlock Text=" - " FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}" FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="Diminuir qtd" FontSize="13"
                                           Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <Separator Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>

                            <TextBlock Text="SISTEMA" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,6" Opacity="0.6"/>
                            <Grid Margin="0,0,0,4">
                                <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="4"
                                        Padding="6,3" HorizontalAlignment="Left">
                                    <TextBlock Text="F10" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}" FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="Configuracoes" FontSize="13"
                                           Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="4"
                                        Padding="6,3" HorizontalAlignment="Left">
                                    <TextBlock Text="F11" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}" FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="Logout" FontSize="13"
                                           Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Separator Background="{DynamicResource SeparatorBrush}" Margin="0,16"/>

                    <TextBlock Text="Ctrl+B = Busca avancada  |  Ctrl+N = Novo cliente  |  3*codigo = 3 unidades"
                               FontSize="12" FontStyle="Italic"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16"/>

                    <Button Content="FECHAR"
                            Command="{Binding FecharAjudaCommand}"
                            Style="{DynamicResource BotaoNeutral}"
                            FontSize="14" Height="40"
                            Padding="30,0"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ============================================= -->
        <!-- OVERLAY BUSCA AVANCADA DE PRODUTOS            -->
        <!-- ============================================= -->
        <Grid Grid.RowSpan="3" Panel.ZIndex="90">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding BuscaAvancadaVisivel}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <!-- Background escuro -->
            <Border Background="#99000000"
                    MouseDown="FecharBuscaAvancada_Click"/>

            <!-- Card central -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="12" Padding="30"
                    Width="700" MaxHeight="600"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Effect="{DynamicResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Titulo + Fechar -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="BUSCA DE PRODUTOS"
                                   Style="{DynamicResource TituloPDV}"
                                   FontSize="22"/>
                        <Button Content="X"
                                Command="{Binding FecharBuscaAvancadaCommand}"
                                HorizontalAlignment="Right"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Background="Transparent" BorderThickness="0"
                                FontSize="18" FontWeight="Bold"
                                Cursor="Hand" Padding="4,0"/>
                    </Grid>

                    <!-- Campo de busca -->
                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding BuscaAvancadaTermo, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource TextBoxPDV}"
                                 FontSize="16" Padding="12,10"
                                 x:Name="TxtBuscaAvancada">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding ExecutarBuscaAvancadaCommand}"/>
                                <KeyBinding Key="Escape" Command="{Binding FecharBuscaAvancadaCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>

                        <Button Grid.Column="1" Content="BUSCAR"
                                Command="{Binding ExecutarBuscaAvancadaCommand}"
                                Style="{DynamicResource BotaoPDV}"
                                FontSize="13" Height="42"
                                Padding="20,0" Margin="8,0,0,0"/>
                    </Grid>

                    <!-- Grid de resultados -->
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding ResultadosBusca}"
                              SelectedItem="{Binding ProdutoBuscaSelecionado}"
                              Style="{DynamicResource DataGridPDV}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              MaxHeight="400"
                              MouseDoubleClick="BuscaAvancada_DoubleClick">
                        <DataGrid.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SelecionarProdutoBuscaCommand}"
                                        CommandParameter="{Binding ProdutoBuscaSelecionado}"/>
                        </DataGrid.InputBindings>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CODIGO" Width="100"
                                                Binding="{Binding CodigoInterno}"/>
                            <DataGridTextColumn Header="DESCRICAO" Width="*"
                                                Binding="{Binding Descricao}"/>
                            <DataGridTextColumn Header="UN" Width="50"
                                                Binding="{Binding UnidadeMedida}"/>
                            <DataGridTextColumn Header="PRECO" Width="100"
                                                Binding="{Binding PrecoVenda, StringFormat=C2}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PositiveBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="ESTOQUE" Width="80"
                                                Binding="{Binding EstoqueAtual, StringFormat=N0}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ============================================= -->
        <!-- OVERLAY CADASTRO RAPIDO DE CLIENTE (Ctrl+N)   -->
        <!-- ============================================= -->
        <Grid Grid.RowSpan="3" Panel.ZIndex="90">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CadastroClienteVisivel}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <!-- Background escuro -->
            <Border Background="#99000000"
                    MouseDown="FecharCadastroCliente_Click"/>

            <!-- Card central -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="16" Padding="40,30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="520"
                    Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets"
                               FontSize="28" HorizontalAlignment="Center"
                               Foreground="{DynamicResource PrimaryBrush}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="CADASTRO RAPIDO DE CLIENTE"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Ctrl+N - Cadastre um cliente sem sair do caixa"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <!-- Nome (obrigatorio) -->
                    <TextBlock Text="Nome *"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="13" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding ClienteNovoNome, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource TextBoxPDV}"
                             FontSize="16" Padding="12,10"
                             Margin="0,0,0,14"
                             x:Name="TxtClienteNome">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Escape" Command="{Binding FecharCadastroClienteCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <!-- CPF/CNPJ -->
                    <TextBlock Text="CPF/CNPJ"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="13" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding ClienteNovoCpfCnpj, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource TextBoxPDV}"
                             FontSize="16" Padding="12,10"
                             MaxLength="18"
                             Margin="0,0,0,14">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Escape" Command="{Binding FecharCadastroClienteCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <!-- Telefone -->
                    <TextBlock Text="Telefone"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="13" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding ClienteNovoTelefone, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource TextBoxPDV}"
                             FontSize="16" Padding="12,10"
                             MaxLength="15"
                             Margin="0,0,0,14">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding CadastrarClienteRapidoCommand}"/>
                            <KeyBinding Key="Escape" Command="{Binding FecharCadastroClienteCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <!-- Mensagem de erro/sucesso -->
                    <TextBlock Text="{Binding CadastroClienteMensagem}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource NegativeBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CadastroClienteMensagem}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Botoes -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button Content="CADASTRAR"
                                Command="{Binding CadastrarClienteRapidoCommand}"
                                Style="{DynamicResource BotaoPositive}"
                                FontSize="14" Height="44"
                                Padding="24,0"
                                Margin="0,0,12,0"/>
                        <Button Content="CANCELAR (ESC)"
                                Command="{Binding FecharCadastroClienteCommand}"
                                Style="{DynamicResource BotaoNeutral}"
                                FontSize="14" Height="44"
                                Padding="24,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
