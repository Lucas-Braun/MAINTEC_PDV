                            <TextBlock Text="Total Vendas" Foreground="{DynamicResource PositiveBrush}" FontSize="13"/>
                            <TextBlock Text="{Binding LxTotalVendas, StringFormat=C2}" HorizontalAlignment="Right"
                                       Foreground="{DynamicResource PositiveBrush}" FontSize="14" FontWeight="Bold"/>
                        </Grid>
                    </Border>

                    <Separator Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>

                    <Border Background="{DynamicResource SurfaceLightBrush}"
                            CornerRadius="8" Padding="16,8" Margin="0,0,0,3">
                        <Grid>
                            <TextBlock Text="Dinheiro" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <TextBlock Text="{Binding LxDinheiro, StringFormat=C2}" HorizontalAlignment="Right"
                                       Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                    </Border>
                    <Border Background="{DynamicResource SurfaceLightBrush}"
                            CornerRadius="8" Padding="16,8" Margin="0,0,0,3">
                        <Grid>
                            <TextBlock Text="Cartao Credito" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <TextBlock Text="{Binding LxCredito, StringFormat=C2}" HorizontalAlignment="Right"
                                       Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                    </Border>
                    <Border Background="{DynamicResource SurfaceLightBrush}"
                            CornerRadius="8" Padding="16,8" Margin="0,0,0,3">
                        <Grid>
                            <TextBlock Text="Cartao Debito" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <TextBlock Text="{Binding LxDebito, StringFormat=C2}" HorizontalAlignment="Right"
                                       Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                    </Border>
                    <Border Background="{DynamicResource SurfaceLightBrush}"
                            CornerRadius="8" Padding="16,8" Margin="0,0,0,3">
                        <Grid>
                            <TextBlock Text="PIX" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <TextBlock Text="{Binding LxPix, StringFormat=C2}" HorizontalAlignment="Right"
                                       Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                    </Border>

                    <Separator Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>

                    <Border Background="{DynamicResource SurfaceLightBrush}"
                            CornerRadius="8" Padding="16,8" Margin="0,0,0,3">
                        <Grid>
                            <TextBlock Text="(-) Sangrias" Foreground="{DynamicResource NegativeBrush}" FontSize="12"/>
                            <TextBlock Text="{Binding LxSangrias, StringFormat=C2}" HorizontalAlignment="Right"
                                       Foreground="{DynamicResource NegativeBrush}" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                    </Border>
                    <Border Background="{DynamicResource SurfaceLightBrush}"
                            CornerRadius="8" Padding="16,8" Margin="0,0,0,3">
                        <Grid>
                            <TextBlock Text="(+) Suprimentos" Foreground="{DynamicResource PositiveBrush}" FontSize="12"/>
                            <TextBlock Text="{Binding LxSuprimentos, StringFormat=C2}" HorizontalAlignment="Right"
                                       Foreground="{DynamicResource PositiveBrush}" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                    </Border>
                    <Border Background="{DynamicResource SurfaceLightBrush}"
                            CornerRadius="8" Padding="16,8" Margin="0,0,0,3">
                        <Grid>
                            <TextBlock Text="(-) Estornos" Foreground="{DynamicResource NegativeBrush}" FontSize="12"/>
                            <TextBlock Text="{Binding LxEstornos, StringFormat=C2}" HorizontalAlignment="Right"
                                       Foreground="{DynamicResource NegativeBrush}" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                    </Border>

                    <Separator Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>

                    <Border Background="{DynamicResource PrimarySubtleBrush}"
                            CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
                        <Grid>
                            <TextBlock Text="SALDO EM CAIXA" Foreground="{DynamicResource PrimaryBrush}"
                                       FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="{Binding LxSaldo, StringFormat=C2}" HorizontalAlignment="Right"
                                       Foreground="{DynamicResource PrimaryBrush}" FontSize="20" FontWeight="ExtraBold"/>
                        </Grid>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="IMPRIMIR"
                                Command="{Binding ImprimirLeituraXCommand}"
                                Style="{DynamicResource BotaoPDV}"
                                FontSize="14" Height="40"
                                Padding="24,0"
                                Margin="0,0,12,0"/>
                        <Button Content="FECHAR"
                                Command="{Binding FecharLeituraXCommand}"
                                Style="{DynamicResource BotaoNeutral}"
                                FontSize="14" Height="40"
                                Padding="24,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ============================================= -->
        <!-- OVERLAY DE CONFIRMACAO CANCELAMENTO           -->
        <!-- ============================================= -->
        <Grid Grid.RowSpan="3" Panel.ZIndex="80">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ConfirmandoCancelamento}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="#88000000"/>
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="16"
                    Padding="40,30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{DynamicResource CardShadow}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="CANCELAR VENDA?"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource NegativeBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Todos os itens serao removidos."
                               FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,24"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button Content="SIM, CANCELAR (F9)"
                                Command="{Binding CancelarVendaCommand}"
                                Style="{DynamicResource BotaoNegative}"
                                FontSize="14" Height="44"
                                Padding="24,0"
                                Margin="0,0,12,0"/>
                        <Button Content="NAO, VOLTAR (ESC)"
                                Command="{Binding DesistirCancelamentoCommand}"
                                Style="{DynamicResource BotaoNeutral}"
                                FontSize="14" Height="44"
                                Padding="24,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ============================================= -->
        <!-- OVERLAY DE DESCONTO (F8)                      -->
        <!-- ============================================= -->
        <Grid Grid.RowSpan="3" Panel.ZIndex="70">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DescontoOverlayVisivel}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="#88000000"/>
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="16"
                    Padding="40,30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="400"
                    Effect="{DynamicResource CardShadow}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="APLICAR DESCONTO (F8)"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Selecione um item ou aplique em todos"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Percentual (%):"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="13" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding DescontoPercentualInput, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource TextBoxPDV}"
                             FontSize="24" FontWeight="Bold"
                             Padding="12,8" TextAlignment="Center"
                             Width="200"
                             Margin="0,0,0,20"
                             x:Name="TxtDesconto">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding AplicarDescontoCommand}"/>
                            <KeyBinding Key="Escape" Command="{Binding FecharDescontoCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button Content="APLICAR"
                                Command="{Binding AplicarDescontoCommand}"
                                Style="{DynamicResource BotaoPositive}"
                                FontSize="14" Height="44"
                                Padding="24,0"
                                Margin="0,0,12,0"/>
                        <Button Content="CANCELAR (ESC)"
                                Command="{Binding FecharDescontoCommand}"
                                Style="{DynamicResource BotaoNeutral}"
                                FontSize="14" Height="44"
                                Padding="24,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ============================================= -->
        <!-- OVERLAY DE PROCESSAMENTO                      -->
        <!-- ============================================= -->
        <Grid Grid.RowSpan="3" Panel.ZIndex="90">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Processando}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="#88000000"/>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="200" Height="4"
                             Foreground="{DynamicResource PrimaryBrush}"
                             Background="{DynamicResource SurfaceLightBrush}"
                             BorderThickness="0"/>
                <TextBlock Text="{Binding MensagemStatus}"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"/>
                <TextBlock Text="{Binding TempoProcessamento}"
                           FontSize="14"
                           Foreground="#AAFFFFFF"
                           HorizontalAlignment="Center"
                           FontFamily="Consolas"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Grid>

