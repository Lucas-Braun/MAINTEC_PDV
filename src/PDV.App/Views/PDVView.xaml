<!-- =============================================
     PDV.App/Views/PDVView.xaml
     Tela principal do caixa - Tema Fiori
     ============================================= -->
<UserControl x:Class="PDV.App.Views.PDVView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="768" d:DesignWidth="1366"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.InputBindings>
        <KeyBinding Key="F1" Command="{Binding RepetirUltimoItemCommand}" />
        <KeyBinding Key="F2" Command="{Binding FinalizarVendaCommand}" />
        <KeyBinding Key="F3" Command="{Binding ConsultarClienteCommand}" />
        <KeyBinding Key="F4" Command="{Binding ConsultarProdutoCommand}" />
        <KeyBinding Key="F5" Command="{Binding RealizarSangriaCommand}" />
        <KeyBinding Key="F6" Command="{Binding RealizarSuprimentoCommand}" />
        <KeyBinding Key="F7" Command="{Binding ConsultarVendasCommand}" />
        <KeyBinding Key="F8" Command="{Binding AbrirDescontoCommand}" />
        <KeyBinding Key="F9" Command="{Binding CancelarVendaCommand}" />
        <KeyBinding Key="F10" Command="{Binding AbrirConfiguracoesCommand}" />
        <KeyBinding Key="F11" Command="{Binding TrocarOperadorCommand}" />
        <KeyBinding Key="F12" Command="{Binding FecharCaixaCommand}" />
        <KeyBinding Key="Delete" Command="{Binding RemoverItemCommand}" />
        <KeyBinding Key="Add" Command="{Binding IncrementarQuantidadeCommand}" />
        <KeyBinding Key="Subtract" Command="{Binding DecrementarQuantidadeCommand}" />
        <KeyBinding Key="B" Modifiers="Ctrl" Command="{Binding AbrirBuscaAvancadaCommand}" />
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AbrirCadastroClienteCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <!-- ============================================= -->
        <!-- HEADER                                        -->
        <!-- ============================================= -->
        <Border Grid.Row="0" Background="{DynamicResource ShellBrush}"
                BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="MEINTEC" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,20,0">
                        <Run Text="Caixa: " />
                        <Run Text="{Binding NumeroCaixa, Mode=OneWay}" FontWeight="Bold"
                             Foreground="{DynamicResource TextBrush}" />
                    </TextBlock>
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,20,0">
                        <Run Text="Operador: " />
                        <Run Text="{Binding MensagemOperador}" FontWeight="Bold"
                             Foreground="{DynamicResource TextBrush}" />
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center" Margin="0,0,20,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ClienteDefinido}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="Cliente: " Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <Run Text="{Binding NomeCliente, Mode=OneWay}" FontWeight="Bold"
                             Foreground="{DynamicResource PositiveBrush}"/>
                        <Run Text=" (" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <Run Text="{Binding CpfCliente, Mode=OneWay}"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <Run Text=")" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </TextBlock>
                    <!-- Botao ajuda -->
                    <Button Command="{Binding MostrarAjudaCommand}"
                            ToolTip="Atalhos de teclado"
                            VerticalAlignment="Center" Margin="0,0,15,0"
                            Cursor="Hand" Width="28" Height="28">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="#20FFFFFF" CornerRadius="14">
                                    <TextBlock Text="?" FontSize="15" FontWeight="Bold"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#40FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock Text="{Binding DataHoraAtual}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               FontFamily="Consolas"
                               FontSize="13" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================= -->
        <!-- CONTEUDO PRINCIPAL                             -->
        <!-- ============================================= -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!-- PAINEL ESQUERDO - Itens da venda -->
            <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="12" Margin="0,0,10,0" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Campo de leitura do codigo de barras -->
                    <Border Grid.Row="0" Background="{DynamicResource SurfaceLightBrush}"
                            CornerRadius="12,12,0,0" Padding="15,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Codigo:"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" FontSize="14" />

                            <TextBox Grid.Column="1"
                                     Text="{Binding CodigoBarrasInput, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="18" FontWeight="Bold"
                                     Background="Transparent"
                                     Foreground="{DynamicResource TextBrush}"
                                     BorderBrush="{DynamicResource PrimaryBrush}"
                                     BorderThickness="0,0,0,2"
                                     Padding="8,5"
                                     CaretBrush="{DynamicResource TextBrush}"
                                     VerticalContentAlignment="Center"
                                     x:Name="TxtCodigoBarras">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter"
                                                Command="{Binding AdicionarProdutoCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>

                            <TextBlock Grid.Column="2" Text="Qtd:"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" FontSize="14"
                                       Margin="15,0,5,0" />

                            <TextBox Grid.Column="3" Width="70"
                                     Text="{Binding QuantidadeInput, StringFormat=N2}"
                                     FontSize="16" FontWeight="Bold"
                                     Background="Transparent"
                                     Foreground="{DynamicResource TextBrush}"
                                     BorderBrush="{DynamicResource PrimaryBrush}"
                                     BorderThickness="0,0,0,2"
                                     Padding="8,5"
                                     CaretBrush="{DynamicResource TextBrush}"
                                     TextAlignment="Center"
                                     VerticalContentAlignment="Center" />

                            <TextBlock Grid.Column="4" Text="CPF nota:"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" FontSize="12"
                                       Margin="15,0,5,0" />

                            <TextBox Grid.Column="5"
                                     Text="{Binding CpfNotaInput, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="13"
                                     Background="Transparent"
                                     Foreground="{DynamicResource TextBrush}"
                                     BorderBrush="{DynamicResource SeparatorBrush}"
                                     BorderThickness="0,0,0,1"
                                     Padding="6,5"
                                     CaretBrush="{DynamicResource TextBrush}"
                                     VerticalContentAlignment="Center"
                                     MaxLength="18"
                                     ToolTip="CPF/CNPJ para nota fiscal"/>
                        </Grid>
                    </Border>

                    <!-- Produtos recentes -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding ProdutosRecentes}"
                                  Margin="8,4,8,0">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ProdutosRecentes.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.AdicionarProdutoRecenteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand" Margin="0,0,4,4"
                                        ToolTip="{Binding Descricao}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{DynamicResource SurfaceLightBrush}"
                                                    CornerRadius="6" Padding="10,4">
                                                <TextBlock Text="{Binding Descricao}" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           MaxWidth="120" TextTrimming="CharacterEllipsis"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="{DynamicResource PrimarySubtleBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Teclado numerico virtual -->
                    <Border Grid.Row="2" Background="{DynamicResource SurfaceLightBrush}"
                            Padding="8,6" Margin="0,0,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TecladoVisivel}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="1" Command="{Binding TeclaCommand}" CommandParameter="1" Style="{DynamicResource BotaoGhost}" Height="38" Margin="2,0" FontSize="16" FontWeight="Bold"/>
                            <Button Grid.Column="1" Content="2" Command="{Binding TeclaCommand}" CommandParameter="2" Style="{DynamicResource BotaoGhost}" Height="38" Margin="2,0" FontSize="16" FontWeight="Bold"/>
                            <Button Grid.Column="2" Content="3" Command="{Binding TeclaCommand}" CommandParameter="3" Style="{DynamicResource BotaoGhost}" Height="38" Margin="2,0" FontSize="16" FontWeight="Bold"/>
                            <Button Grid.Column="3" Content="4" Command="{Binding TeclaCommand}" CommandParameter="4" Style="{DynamicResource BotaoGhost}" Height="38" Margin="2,0" FontSize="16" FontWeight="Bold"/>
                            <Button Grid.Column="4" Content="5" Command="{Binding TeclaCommand}" CommandParameter="5" Style="{DynamicResource BotaoGhost}" Height="38" Margin="2,0" FontSize="16" FontWeight="Bold"/>
                            <Button Grid.Column="5" Content="6" Command="{Binding TeclaCommand}" CommandParameter="6" Style="{DynamicResource BotaoGhost}" Height="38" Margin="2,0" FontSize="16" FontWeight="Bold"/>
                            <Button Grid.Column="6" Content="7" Command="{Binding TeclaCommand}" CommandParameter="7" Style="{DynamicResource BotaoGhost}" Height="38" Margin="2,0" FontSize="16" FontWeight="Bold"/>
                            <Button Grid.Column="7" Content="8" Command="{Binding TeclaCommand}" CommandParameter="8" Style="{DynamicResource BotaoGhost}" Height="38" Margin="2,0" FontSize="16" FontWeight="Bold"/>
                            <Button Grid.Column="8" Content="9" Command="{Binding TeclaCommand}" CommandParameter="9" Style="{DynamicResource BotaoGhost}" Height="38" Margin="2,0" FontSize="16" FontWeight="Bold"/>
                            <Button Grid.Column="9" Content="0" Command="{Binding TeclaCommand}" CommandParameter="0" Style="{DynamicResource BotaoGhost}" Height="38" Margin="2,0" FontSize="16" FontWeight="Bold"/>
                            <Button Grid.Column="10" Content="&#xE750;" FontFamily="Segoe MDL2 Assets" Command="{Binding TeclaCommand}" CommandParameter="BS" Style="{DynamicResource BotaoGhost}" Height="38" Margin="2,0" FontSize="14" ToolTip="Apagar"/>
                            <Button Grid.Column="11" Content="OK" Command="{Binding TeclaCommand}" CommandParameter="OK" Style="{DynamicResource BotaoPositive}" Height="38" Margin="2,0" FontSize="13" FontWeight="Bold"/>
                        </Grid>
                    </Border>

                    <!-- Grid de itens da venda -->
                    <Grid Grid.Row="3">
                        <DataGrid x:Name="GridItens"
                                  ItemsSource="{Binding Itens}"
                                  SelectedItem="{Binding ItemSelecionado}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserSortColumns="False"
                                  CellEditEnding="DataGrid_CellEditEnding"
                                  Style="{DynamicResource DataGridPDV}"
                                  AlternatingRowBackground="#08FFFFFF">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Width="45"
                                    Binding="{Binding NumeroItem}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="CODIGO" Width="130"
                                    Binding="{Binding CodigoBarras}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="DESCRICAO" Width="*"
                                    Binding="{Binding DescricaoProduto}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="UN" Width="50"
                                    Binding="{Binding UnidadeMedida}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="QTD" Width="70"
                                    Binding="{Binding Quantidade, StringFormat=N2}">
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceLightBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="SelectionBrush" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="4,2"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="VL. UNIT." Width="100"
                                    Binding="{Binding PrecoUnitario, StringFormat=C2}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="DESCONTO" Width="90"
                                    Binding="{Binding DescontoValor, StringFormat=C2}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="TOTAL" Width="110"
                                    Binding="{Binding ValorTotal, StringFormat=C2}" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold" />
                                            <Setter Property="Foreground"
                                                    Value="{DynamicResource PositiveBrush}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Empty state -->
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding VendaEmAndamento}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="&#xE8A5;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="48"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       Opacity="0.4"
                                       Margin="0,0,0,16"/>
                            <TextBlock Text="Leia um codigo de barras para iniciar"
                                       FontSize="16"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       Opacity="0.6"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- PAINEL LATERAL DIREITO - Totais e Acoes -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Ultimo item adicionado -->
                <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="12" Padding="16" Margin="0,0,0,10">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding UltimoItemDescricao}" Value="">
                                    <Setter Property="Opacity" Value="0.5" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Foto do produto -->
                        <Border Grid.Column="0" Width="64" Height="64"
                                CornerRadius="8" Margin="0,0,14,0"
                                Background="{DynamicResource SurfaceLightBrush}">
                            <Grid>
                                <TextBlock Text="&#xE722;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="24"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Opacity="0.3"/>
                                <Image Source="{Binding UltimoItemFotoUrl}"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="ULTIMO ITEM (F1 repetir)"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="10" FontWeight="SemiBold" />

                            <TextBlock Grid.Row="1"
                                       Text="{Binding UltimoItemDescricao}"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="13" FontWeight="Bold"
                                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                       MaxHeight="36"
                                       Margin="0,4,0,0" />

                            <TextBlock Grid.Row="2"
                                       Text="{Binding UltimoItemQtd}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,2,0,0" />

                            <TextBlock Grid.Row="3"
                                       Text="{Binding UltimoItemPreco}"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       FontSize="26" FontWeight="ExtraBold"
                                       HorizontalAlignment="Right"
                                       Margin="0,2,0,0" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- Totais -->
                <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="12" Padding="20" Margin="0,0,0,10">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Subtotal:"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="14" />
                            <TextBlock Text="{Binding SubTotal, StringFormat=C2}"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Right" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Desconto:"
                                       Foreground="{DynamicResource NegativeBrush}"
                                       FontSize="14" />
                            <TextBlock Text="{Binding DescontoTotal, StringFormat=C2}"
                                       Foreground="{DynamicResource NegativeBrush}"
                                       FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Right" />
                        </Grid>

                        <Separator Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,0" />

                        <!-- Total da venda - destaque grande -->
                        <Border Background="{DynamicResource PrimarySubtleBrush}"
                                CornerRadius="10" Padding="16,14" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="TOTAL DA VENDA"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11" FontWeight="SemiBold" />

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                            HorizontalAlignment="Right">
                                    <TextBlock Text="R$ "
                                               Foreground="{DynamicResource PositiveBrush}"
                                               FontSize="22" FontWeight="Normal"
                                               VerticalAlignment="Bottom" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding ValorTotal, StringFormat=N2}"
                                               Foreground="{DynamicResource PositiveBrush}"
                                               FontSize="42" FontWeight="ExtraBold" />
                                </StackPanel>

                                <Border Background="{DynamicResource PrimaryBrush}"
                                        CornerRadius="10" Padding="10,3"
                                        HorizontalAlignment="Left"
                                        Margin="0,6,0,0">
                                    <TextBlock Foreground="White" FontSize="12" FontWeight="SemiBold">
                                        <Run Text="{Binding TotalItens, Mode=OneWay}"/>
                                        <Run Text=" itens"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Botoes de funcao -->
                <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="12" Padding="10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Grupo: Venda -->
                            <TextBlock Text="VENDA" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="6,2,0,4" Opacity="0.6"/>
                            <WrapPanel>
                                <Button Style="{DynamicResource BotaoFuncao}"
                                        Background="{DynamicResource PositiveBrush}"
                                        Command="{Binding FinalizarVendaCommand}"
                                        ToolTip="Finalizar venda e ir para pagamento (F2)">
                                    <StackPanel>
                                        <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="18" HorizontalAlignment="Center"/>
                                        <TextBlock Text="PAGAMENTO" FontSize="11" FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="F2" FontSize="9" Opacity="0.6"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{DynamicResource BotaoFuncao}"
                                        Background="{DynamicResource NeutralBrush}"
                                        Command="{Binding AbrirDescontoCommand}"
                                        ToolTip="Aplicar desconto no item ou venda (F8)">
                                    <StackPanel>
                                        <TextBlock Text="&#xE8EF;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="18" HorizontalAlignment="Center"/>
                                        <TextBlock Text="DESCONTO" FontSize="11" FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="F8" FontSize="9" Opacity="0.6"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{DynamicResource BotaoFuncao}"
                                        Background="{DynamicResource NegativeBrush}"
                                        Command="{Binding CancelarVendaCommand}"
                                        ToolTip="Cancelar a venda atual (F9)">
                                    <StackPanel>
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="18" HorizontalAlignment="Center"/>
                                        <TextBlock Text="CANCELAR" FontSize="11" FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="F9" FontSize="9" Opacity="0.6"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </WrapPanel>

                            <Separator Background="{DynamicResource SeparatorBrush}" Margin="4,6"/>

                            <!-- Grupo: Consultas -->
                            <TextBlock Text="CONSULTAS" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="6,0,0,4" Opacity="0.6"/>
                            <WrapPanel>
                                <Button Style="{DynamicResource BotaoFuncao}"
                                        Background="{DynamicResource PrimaryBrush}"
                                        Command="{Binding ConsultarClienteCommand}"
                                        ToolTip="Consultar ou cadastrar cliente (F3)">
                                    <StackPanel>
                                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="18" HorizontalAlignment="Center"/>
                                        <TextBlock Text="CLIENTE" FontSize="11" FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="F3" FontSize="9" Opacity="0.6"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{DynamicResource BotaoFuncao}"
                                        Background="{DynamicResource PrimaryBrush}"
                                        Command="{Binding ConsultarProdutoCommand}"
                                        ToolTip="Consultar produto por nome ou codigo (F4)">
                                    <StackPanel>
                                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="18" HorizontalAlignment="Center"/>
