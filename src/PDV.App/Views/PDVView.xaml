        <!-- ============================================= -->
        <!-- STATUS BAR                                     -->
        <!-- ============================================= -->
        <Border Grid.Row="2" Background="{DynamicResource ShellBrush}"
                BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding MensagemStatus}"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center" FontSize="13" />

                <!-- Sync pendentes indicator -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="20,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TemVendasPendentes}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets"
                               FontSize="12" Foreground="#FFA500"
                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding StatusSyncTexto}"
                               Foreground="#FFA500" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="20,0">
                    <Ellipse Width="8" Height="8" Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource NegativeBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NfceOnline}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource PositiveBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusNfceTexto}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12" />
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="20,0">
                    <Ellipse Width="8" Height="8" Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource NegativeBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TefConectado}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource PositiveBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusTefTexto}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12" />
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource NegativeBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ApiConectada}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource PositiveBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusApiTexto}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================= -->
        <!-- OVERLAY LEITURA X                             -->
        <!-- ============================================= -->
        <Grid Grid.RowSpan="3" Panel.ZIndex="85">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding LeituraXVisivel}" Value="True">
