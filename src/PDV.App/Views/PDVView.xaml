                    <TextBlock Text="&#xE9D5;" FontFamily="Segoe MDL2 Assets"
                               FontSize="28" HorizontalAlignment="Center"
                               Foreground="{DynamicResource PrimaryBrush}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="LEITURA X"
