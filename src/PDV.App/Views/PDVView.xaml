        <!-- TOAST NOTIFICATION                            -->
        <!-- ============================================= -->
        <Border Grid.Row="0" Panel.ZIndex="100"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,20,8" CornerRadius="8" Padding="16,10"
                MinWidth="200" MaxWidth="420">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ToastVisivel}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ToastTipo}" Value="sucesso">
                            <Setter Property="Background" Value="{DynamicResource PositiveBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ToastTipo}" Value="erro">
                            <Setter Property="Background" Value="{DynamicResource NegativeBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14"
                           Foreground="White" VerticalAlignment="Center"
                           Margin="0,0,10,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="&#xE946;"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ToastTipo}" Value="sucesso">
                                    <Setter Property="Text" Value="&#xE73E;"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ToastTipo}" Value="erro">
                                    <Setter Property="Text" Value="&#xE783;"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding ToastMensagem}" Foreground="White"
                           FontSize="13" FontWeight="SemiBold"
                           TextWrapping="Wrap" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

