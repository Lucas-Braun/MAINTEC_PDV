<UserControl x:Class="PDV.App.Views.ConsultaProdutoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding VoltarCommand}"/>
    </UserControl.InputBindings>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Campo de busca -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                CornerRadius="12" Padding="20" Margin="0,0,0,10"
                Effect="{DynamicResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="CONSULTA DE PRODUTO"
                           Style="{DynamicResource TituloPDV}"
                           FontSize="22"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>

                <TextBox Grid.Column="1"
                         Text="{Binding TermoBusca, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource TextBoxPDV}"
                         FontSize="18" Padding="12,10"
                         x:Name="TxtBusca">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding PesquisarCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <Button Grid.Column="2" Content="PESQUISAR"
                        Command="{Binding PesquisarCommand}"
                        Style="{DynamicResource BotaoPDV}"
                        FontSize="14" Height="42"
                        Margin="10,0,0,0"
                        IsEnabled="{Binding Processando, Converter={StaticResource InvertBool}}"/>
            </Grid>
        </Border>

        <!-- Grid de produtos -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}"
                CornerRadius="12" Padding="0" Margin="0,0,0,10"
                Effect="{DynamicResource CardShadow}">
            <DataGrid ItemsSource="{Binding Produtos}"
                      SelectedItem="{Binding ProdutoSelecionado}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Style="{DynamicResource DataGridPDV}">
                <DataGrid.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding SelecionarCommand}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="CODIGO" Width="120"
                        Binding="{Binding CodigoInterno}"/>
                    <DataGridTextColumn Header="COD. BARRAS" Width="150"
                        Binding="{Binding CodigoBarras}"/>
                    <DataGridTextColumn Header="DESCRICAO" Width="*"
                        Binding="{Binding Descricao}"/>
                    <DataGridTextColumn Header="PRECO" Width="120"
                        Binding="{Binding PrecoVenda, StringFormat=C2}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource PositiveBrush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="ESTOQUE" Width="100"
                        Binding="{Binding EstoqueAtual, StringFormat=N2}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EstoqueAtual, Converter={StaticResource EstoqueBaixo}}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource NegativeBrush}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Botoes -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Loading -->
            <TextBlock Grid.Column="0"
                       Text="Pesquisando..."
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       Visibility="{Binding Processando, Converter={StaticResource BoolToVisibility}}"/>

            <Button Grid.Column="1" Content="VOLTAR (ESC)"
                    Command="{Binding VoltarCommand}"
                    Style="{DynamicResource BotaoNeutral}"
                    FontSize="14" Height="48"
                    Margin="0,0,10,0"/>

            <Button Grid.Column="2" Content="SELECIONAR"
                    Command="{Binding SelecionarCommand}"
                    Style="{DynamicResource BotaoPositive}"
                    FontSize="14" Height="48"/>
        </Grid>
    </Grid>

</UserControl>
