<UserControl x:Class="PDV.App.Views.SangriaSuprimentoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding VoltarCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Card central -->
        <Border Grid.Column="1"
                VerticalAlignment="Center"
                Width="480"
                Background="{DynamicResource SurfaceBrush}"
                CornerRadius="12"
                Padding="40,36"
                Effect="{DynamicResource CardShadow}">

            <StackPanel>
                <!-- Titulo -->
                <TextBlock Text="{Binding Titulo}"
                           Style="{DynamicResource TituloPDV}"
                           FontSize="28"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>

                <TextBlock Text="{Binding Descricao}"
                           Style="{DynamicResource SubtituloPDV}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Saldo atual do caixa -->
                <Border Background="{DynamicResource SurfaceLightBrush}"
                        CornerRadius="8" Padding="16,10"
                        Margin="0,0,0,24">
                    <Grid>
                        <TextBlock Text="SALDO ATUAL DO CAIXA"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SaldoCaixa, StringFormat=C2}"
                                   Foreground="{DynamicResource PositiveBrush}"
                                   FontSize="20" FontWeight="ExtraBold"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Valor -->
                <TextBlock Text="VALOR (R$)"
                           Style="{DynamicResource LabelPDV}"/>

                <TextBox Text="{Binding Valor, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource TextBoxPDV}"
                         FontSize="22" FontWeight="Bold"
                         Padding="12,10"
                         Margin="0,0,0,8"
                         x:Name="TxtValor">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding ConfirmarCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <!-- Botoes de valor rapido -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,16">
                    <Button Content="R$ 50"
                            Command="{Binding DefinirValorCommand}"
                            CommandParameter="50"
                            Style="{DynamicResource BotaoGhost}"
                            FontSize="13" Padding="14,6"
                            Margin="0,0,6,0"/>
                    <Button Content="R$ 100"
                            Command="{Binding DefinirValorCommand}"
                            CommandParameter="100"
                            Style="{DynamicResource BotaoGhost}"
                            FontSize="13" Padding="14,6"
                            Margin="0,0,6,0"/>
                    <Button Content="R$ 200"
                            Command="{Binding DefinirValorCommand}"
                            CommandParameter="200"
                            Style="{DynamicResource BotaoGhost}"
                            FontSize="13" Padding="14,6"/>
                </StackPanel>

                <!-- Observacao -->
                <TextBlock Text="OBSERVACAO"
                           Style="{DynamicResource LabelPDV}"/>

                <TextBox Text="{Binding Observacao, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource TextBoxPDV}"
                         FontSize="14"
                         Padding="12,10"
                         Height="80"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,24"/>

                <!-- Mensagem de erro -->
                <TextBlock Text="{Binding MensagemErro}"
                           Foreground="{DynamicResource NegativeBrush}"
                           FontSize="13"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"
                           Visibility="{Binding MensagemErro, Converter={StaticResource StringToVisibility}}"/>

                <!-- Botoes -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="VOLTAR (ESC)"
                            Command="{Binding VoltarCommand}"
                            Style="{DynamicResource BotaoNeutral}"
                            FontSize="14" Height="48"
                            Margin="0,0,5,0"/>

                    <Button Grid.Column="1" Content="CONFIRMAR"
                            Command="{Binding ConfirmarCommand}"
                            Style="{DynamicResource BotaoPositive}"
                            FontSize="14" Height="48"
                            IsEnabled="{Binding Processando, Converter={StaticResource InvertBool}}"
                            Margin="5,0,0,0"/>
                </Grid>

                <!-- Loading -->
                <TextBlock Text="Processando..."
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"
                           Visibility="{Binding Processando, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Historico de movimentacoes -->
                <Border Margin="0,20,0,0"
                        Background="{DynamicResource SurfaceLightBrush}"
                        CornerRadius="8" Padding="16,12">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TemMovimentos}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="ULTIMAS MOVIMENTACOES"
                                   Style="{DynamicResource LabelPDV}"
                                   Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Movimentos}" MaxHeight="150">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding DataHora, StringFormat=HH:mm}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="12" FontFamily="Consolas"
                                                   Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Tipo}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="12"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Valor, StringFormat=C2}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>

</UserControl>
