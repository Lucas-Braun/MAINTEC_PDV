<Application x:Class="PDV.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PDV.App.Converters">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Tema Fiori (troque por DarkTheme.xaml para voltar ao antigo) -->
                <ResourceDictionary Source="Themes/FioriTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters globais -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <conv:InvertBoolConverter x:Key="InvertBool"/>
            <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibility"/>
            <conv:StringToVisibilityConverter x:Key="StringToVisibility"/>
            <conv:BoolToStatusColorConverter x:Key="BoolToStatusColor"/>
            <conv:BoolToConnectionTextConverter x:Key="BoolToConnectionText"/>
            <conv:CurrencyConverter x:Key="Currency"/>
            <conv:IsNegativeConverter x:Key="IsNegative"/>
            <conv:EstoqueBaixoConverter x:Key="EstoqueBaixo"/>
        </ResourceDictionary>
    </Application.Resources>

</Application>
